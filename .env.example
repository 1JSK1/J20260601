# Backend runtime data directory. Leave empty to use backend/data locally.
ZHIKONG_DATA_DIR=

# Example-only values. Do not commit real service credentials.
TENCENT_ASR_APP_ID=
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=

# Example pairing token for local development only.
ZHIKONG_PAIRING_TOKEN=dev-token
